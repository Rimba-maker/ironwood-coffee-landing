---
import { Icon } from 'astro-icon/components';
---

<section id="lokasi" class="py-24 lg:py-36" style="background: var(--color-surface);">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-16">

      <!-- Info -->
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.3em] mb-3" style="color: var(--color-amber);">
          Temukan Kami
        </p>
        <h2
          class="font-display uppercase mb-10"
          style="font-size: clamp(40px, 6vw, 72px); line-height: 0.92; color: var(--color-text);"
        >
          Datang<br />Langsung.
        </h2>

        <!-- Info blocks with Solar icons -->
        <div class="space-y-6">

          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-lg flex items-center justify-center shrink-0" style="background: var(--color-iron);">
              <Icon name="solar:map-point-bold-duotone" class="w-5 h-5" style="color: var(--color-amber);" />
            </div>
            <div>
              <p class="text-xs uppercase tracking-widest mb-1" style="color: var(--color-text-dim);">Alamat</p>
              <p style="color: var(--color-text); line-height: 1.7;">
                Jl. Kemang Raya No. 45, Kemang<br />
                Jakarta Selatan, DKI Jakarta 12730
              </p>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-lg flex items-center justify-center shrink-0" style="background: var(--color-iron);">
              <Icon name="solar:clock-circle-bold-duotone" class="w-5 h-5" style="color: var(--color-amber);" />
            </div>
            <div>
              <p class="text-xs uppercase tracking-widest mb-1" style="color: var(--color-text-dim);">Jam Buka</p>
              <div class="space-y-1" style="color: var(--color-text);">
                <p><span style="color: var(--color-text-muted);">Senin – Jumat</span>&nbsp;&nbsp;08.00 – 23.00</p>
                <p><span style="color: var(--color-text-muted);">Sabtu – Minggu</span>&nbsp;&nbsp;07.00 – 24.00</p>
              </div>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-lg flex items-center justify-center shrink-0" style="background: var(--color-iron);">
              <Icon name="solar:chat-round-call-bold-duotone" class="w-5 h-5" style="color: var(--color-amber);" />
            </div>
            <div>
              <p class="text-xs uppercase tracking-widest mb-1" style="color: var(--color-text-dim);">Reservasi & Info</p>
              <a
                href="https://wa.me/628123456789"
                class="transition-colors duration-200"
                style="color: var(--color-text-muted);"
                onmouseover="this.style.color='var(--color-amber)'"
                onmouseout="this.style.color='var(--color-text-muted)'"
              >
                +62 812-3456-789 (WA)
              </a>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-lg flex items-center justify-center shrink-0" style="background: var(--color-iron);">
              <Icon name="solar:garage-bold-duotone" class="w-5 h-5" style="color: var(--color-amber);" />
            </div>
            <div>
              <p class="text-xs uppercase tracking-widest mb-1" style="color: var(--color-text-dim);">Parkir</p>
              <p style="color: var(--color-text-muted);">40 mobil — Basement + Outdoor</p>
            </div>
          </div>

        </div>

        <!-- CTA -->
        <div class="flex flex-wrap gap-4 mt-10">
          <a
            href="https://maps.google.com"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-7 py-3.5 text-sm font-semibold uppercase tracking-widest rounded-full transition-all duration-200"
            style="background: var(--color-amber); color: var(--color-bg);"
            onmouseover="this.style.background='var(--color-amber-deep)'"
            onmouseout="this.style.background='var(--color-amber)'"
          >
            <Icon name="solar:map-point-bold-duotone" class="w-4 h-4" />
            Buka di Maps
          </a>
          <a
            href="https://wa.me/628123456789"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-7 py-3.5 text-sm font-semibold uppercase tracking-widest rounded-full transition-all duration-200"
            style="border: 1px solid var(--color-hairline); color: var(--color-text);"
            onmouseover="this.style.borderColor='var(--color-amber)'"
            onmouseout="this.style.borderColor='var(--color-hairline)'"
          >
            <Icon name="solar:chat-round-call-bold-duotone" class="w-4 h-4" />
            Book Private Booth
          </a>
        </div>
      </div>

      <!-- Map embed -->
      <div class="relative overflow-hidden" style="min-height: 480px;">
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3966.0!2d106.8!3d-6.26!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zNsKwMTUnMzYuMCJTIDEwNsKwNDgnMDAuMCJF!5e0!3m2!1sen!2sid!4v1234567890"
          class="w-full h-full absolute inset-0"
          style="border: none; filter: grayscale(90%) invert(5%) brightness(0.6) contrast(1.2);"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Ironwood Coffee location"
        ></iframe>
        <div class="absolute bottom-0 left-0 right-0 h-1" style="background: var(--color-amber);" />
      </div>

    </div>
  </div>
</section>
