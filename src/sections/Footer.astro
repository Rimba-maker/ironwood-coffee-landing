---
---

<footer style="background: var(--color-bg); border-top: 1px solid var(--color-hairline);">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">

    <!-- Top row -->
    <div class="grid lg:grid-cols-4 gap-12 py-16" style="border-bottom: 1px solid var(--color-hairline);">

      <!-- Brand -->
      <div class="lg:col-span-1">
        <p class="font-display text-3xl uppercase mb-2" style="color: var(--color-text); letter-spacing: 0.1em;">
          Ironwood <span style="color: var(--color-amber);">Coffee</span>
        </p>
        <p class="text-xs italic mb-6" style="color: var(--color-text-dim);">
          Kopi Serius. Suasana Yang Gak Biasa.
        </p>
        <!-- Socmed -->
        <div class="flex gap-4">
          {[
            { label: 'Instagram', href: '#', icon: 'M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z' },
            { label: 'TikTok', href: '#', icon: 'M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.79a8.18 8.18 0 004.78 1.53V6.86a4.85 4.85 0 01-1.01-.17z' },
          ].map(({ label, href, icon }) => (
            <a
              href={href}
              aria-label={label}
              class="w-9 h-9 rounded-full flex items-center justify-center transition-colors duration-200"
              style="border: 1px solid var(--color-hairline); color: var(--color-text-muted);"
              onmouseover="this.style.borderColor='var(--color-amber)';this.style.color='var(--color-amber)'"
              onmouseout="this.style.borderColor='var(--color-hairline)';this.style.color='var(--color-text-muted)'"
            >
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                <path d={icon} />
              </svg>
            </a>
          ))}
        </div>
      </div>

      <!-- Links -->
      {[
        { title: 'Menu', links: ['Coffee', 'Non-Coffee', 'Food', 'Workshop Kopi'] },
        { title: 'Info', links: ['The Space', 'Work From Here', 'Events & Live Music', 'Community Table'] },
        { title: 'Kontak', links: ['Reservasi Booth', 'WhatsApp', 'Instagram DM', 'Karir di Ironwood'] },
      ].map(({ title, links }) => (
        <div>
          <p class="text-xs font-semibold uppercase tracking-widest mb-5" style="color: var(--color-text);">
            {title}
          </p>
          <ul class="space-y-3">
            {links.map((link) => (
              <li>
                <a
                  href="#"
                  class="text-sm transition-colors duration-200"
                  style="color: var(--color-text-muted);"
                  onmouseover="this.style.color='var(--color-text)'"
                  onmouseout="this.style.color='var(--color-text-muted)'"
                >
                  {link}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <!-- Bottom bar -->
    <div class="flex flex-col lg:flex-row items-center justify-between gap-4 py-6">
      <p class="text-xs" style="color: var(--color-text-dim);">
        © 2024 Ironwood Coffee. All rights reserved.
      </p>
      <p class="text-xs" style="color: var(--color-text-dim);">
        Jl. Kemang Raya No. 45, Jakarta Selatan
      </p>
    </div>

  </div>
</footer>
